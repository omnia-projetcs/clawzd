# ============================================================
# Clawzd — Environment Configuration
# Copy this file to .env and fill in your values.
# ============================================================

# --- LLM Providers ---
# Available: ollama | anthropic | google | grok | groq | huggingface | mistral | openai | openrouter
# Set ENABLE_CLOUD_MODELS=false to run in fully offline/local mode (Ollama only).
# This can also be toggled at runtime in Settings → "Cloud AI Models".
ENABLE_CLOUD_MODELS=true
LLM_PROVIDER=ollama
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
GROK_API_KEY=
GROQ_API_KEY=
HUGGINGFACE_API_KEY=
MISTRAL_API_KEY=
OLLAMA_API_KEY=                       # optional — for secured/remote Ollama instances
OPENAI_API_KEY=
OPENROUTER_API_KEY=
TAVILY_API_KEY=

# --- Ollama (local LLM backend) ---
OLLAMA_VERIFY_SSL=false
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen3.5:9b
# Model used for prompt enrichment (image/video/chat). Must be a fast, non-reasoning
# instruction model — reasoning models (<think> chains) waste the token budget.
ENHANCE_MODEL=hf.co/unsloth/GLM-4.7-Flash-REAP-23B-A3B-GGUF:Q4_K_S
OLLAMA_NUM_GPU=999                    # 999 = all layers on GPU (100% VRAM)
OLLAMA_NUM_CTX=-1                     # -1 = max context window

# --- Application Paths (defaults are relative to project root) ---
# CHROMA_DB_PATH=
# DATA_DIR=
# WORKSPACE_DIR=
# STATIC_DIR=
# TEMPLATES_DIR=
# AGENTS_DIR=
# DB_PATH=
# SETTINGS_PATH=

# --- Security ---
API_SECRET_TOKEN=                     # empty = no auth required
CORS_ORIGINS=                         # comma-separated origins, empty = allow all
RATE_LIMIT=30/minute

# --- Notifications ---
SLACK_WEBHOOK_URL=
NOTIFICATION_EMAIL=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# --- Social & Process Integrations ---
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_SECRET=
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_AUTHOR_ID=
MEDIUM_INTEGRATION_TOKEN=
MEDIUM_AUTHOR_ID=
N8N_WEBHOOK_URL=

# --- Integrations ---
DISCORD_BOT_TOKEN=
TELEGRAM_BOT_TOKEN=

# --- Server ---
APP_HOST=0.0.0.0
APP_PORT=8888

# --- Debug ---
# Enable hot-reload: the server restarts automatically when source
# files are modified (app/, templates/, static/, config.py…).
# Excludes dynamic data: data/, chroma_db/, workspace/, models/, *.db
DEBUG=false
